# 这里只使用 KEY=VALUE，不要添加 export。含空格或特殊字符时使用双引号。
TVHMON_HOST=0.0.0.0
TVHMON_PORT=8088
TVHMON_POLL_SECONDS=10
TVHMON_FULL_SYNC_SECONDS=300

# 外部访问时取消注释并修改。实际文件必须保持 0600 权限。
# TVHMON_WEB_USERNAME=admin
# TVHMON_WEB_PASSWORD="replace-with-a-long-password"
# TVHMON_TRUSTED_PROXIES=127.0.0.1/32,::1/128
# TVHMON_COOKIE_SECURE=1
# TVHMON_ALLOWED_HOST=tv.example.com
# TVHMON_REQUIRE_HTTPS=1

# Tvheadend 只读媒体转发端口，0 表示关闭。
# TVHMON_FORWARD_PORT=9991
